# Production Environment Variables for Vercel
# Copy these to Vercel Environment Variables in your dashboard

# No VITE_API_URL needed - Vercel handles API routes automatically
# Your API routes will be available at /api/* on the same domain

# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/studybuddy

# Session secret (generate a random string)
SESSION_SECRET=your-super-secret-session-key

# Google OAuth (update callback URL to your Vercel domain)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-app.vercel.app/api/auth/google/callback

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@yourdomain.com

# Groq AI
GROQ_API_KEY=your-groq-api-key

# Admin Configuration
ADMIN_EMAIL=admin@studybuddy.com

# Client URL (your Vercel domain)
CLIENT_URL=https://your-app.vercel.app
