# Production Environment Variables Template
# Copy to .env and fill in secrets before deploying

NODE_ENV=production
PORT=3001

# MongoDB Atlas (Production Database)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/studybuddy_prod?retryWrites=true&w=majority

# JWT Secrets — MUST be different for each token type
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Client URL
CLIENT_URL=https://sbd.satym.in

# CORS
ALLOWED_ORIGINS=https://sbd.satym.in,capacitor://localhost,https://localhost

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.satym.in/api/auth/google/callback

# Resend (Email)
RESEND_API_KEY=
EMAIL_FROM=StudyBuddy <noreply@satym.in>

# Admin
ADMIN_EMAIL=

# AI
GROQ_API_KEY=

# Render Keep-Alive
KEEP_ALIVE=true
SELF_URL=https://api.satym.in
