# Staging Environment Variables Template

NODE_ENV=staging
PORT=3001

# MongoDB Atlas (Staging Database — MUST be different from production)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/studybuddy_staging?retryWrites=true&w=majority

# JWT Secrets — MUST be different from production
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Client URL
CLIENT_URL=https://staging.sbd.satym.in

# CORS
ALLOWED_ORIGINS=https://staging.sbd.satym.in,http://localhost:5173

# Google OAuth (use test/staging credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api-staging.satym.in/api/auth/google/callback

# Resend (Email)
RESEND_API_KEY=
EMAIL_FROM=StudyBuddy Staging <staging@satym.in>

# Admin
ADMIN_EMAIL=

# AI
GROQ_API_KEY=

# Render Keep-Alive (not needed for staging)
KEEP_ALIVE=false
